# LLM API Configuration (supports any LLM API with OpenAI SDK format)
# Recommended: Alibaba Qwen-plus model via Bailian Platform: https://bailian.console.aliyun.com/
# High consumption — try simulations with fewer than 40 rounds first
LLM_API_KEY=your_api_key_here
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL_NAME=qwen-plus

# ===== Zep Memory Graph Configuration =====
# Free monthly quota is sufficient for simple usage: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== Boost LLM Configuration (Optional) =====
# Note: if you do not use the boost configuration, do not include the following variables in the env file
LLM_BOOST_API_KEY=your_api_key_here
LLM_BOOST_BASE_URL=your_base_url_here
LLM_BOOST_MODEL_NAME=your_model_name_here

# To use OpenRouter instead of the default Alibaba Qwen endpoint, set:
# LLM_API_KEY=sk-or-v1-your-openrouter-key-here
# LLM_BASE_URL=https://openrouter.ai/api/v1
# LLM_MODEL_NAME=openai/gpt-4o-mini